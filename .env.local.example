############
# Local Self-Contained Mode Configuration
# Copy this to .env.local and adjust as needed:
#   cp .env.local.example .env.local
############

# ─── Backend Mode ─────────────────────────────────────────────
VITE_BACKEND_MODE=local
VITE_LOCAL_API_URL=http://localhost:3001

# These are required by the Vite build but unused in local mode:
VITE_SUPABASE_URL=http://localhost:3001
VITE_SUPABASE_PUBLISHABLE_KEY=unused
VITE_SUPABASE_PROJECT_ID=local

# ─── Database ─────────────────────────────────────────────────
POSTGRES_DB=perleplade
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# ─── Backend ──────────────────────────────────────────────────
BACKEND_PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRY=24h

# ─── Frontend ─────────────────────────────────────────────────
APP_PORT=8080
